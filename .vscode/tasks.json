{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Auto-Start Quarkus",
      "type": "shell",
      "command": "mvn compile quarkus:dev -Dquarkus.http.host=0.0.0.0",
      "options": {
        "cwd": "${workspaceFolder}/hello-world"
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
